{
  "master": {
    "ping": {
      "description": "Master alive check",
      "responseFormat": "ok:msg=Master ready"
    },
    "whoami": {
      "description": "Master device identification",
      "responseFormat": "ok:device=master:type=pico_master"
    },
    "status": {
      "description": "Get master and all slave status",
      "responseFormat": "ok:master=ready:slaves_configured=X"
    }
  },
  "stepper": {
    "ping": {
      "description": "Stepper alive check"
    },
    "whoami": {
      "description": "Stepper device identification"
    },
    "status": {
      "description": "Get stepper status",
      "responseFormat": "ok:position=X:calibrated=X:enabled=X:at_home=X"
    },
    "enable": {
      "description": "Enable stepper motor"
    },
    "disable": {
      "description": "Disable stepper motor"
    },
    "home": {
      "description": "Find and calibrate home position"
    },
    "move": {
      "description": "Move to absolute angle",
      "args": ["degrees"],
      "notes": "Angle in degrees (0-360)"
    },
    "rotate": {
      "description": "Rotate by relative amount",
      "args": ["delta_degrees"],
      "notes": "Positive = CW, Negative = CCW"
    },
    "spin": {
      "description": "Start continuous rotation",
      "args": ["speed_us"],
      "notes": "Speed in microseconds (500-10000)"
    },
    "stop": {
      "description": "Stop continuous rotation"
    },
    "speed": {
      "description": "Set motor speed",
      "args": ["speed_us"],
      "notes": "Pulse duration in microseconds"
    }
  },
  "RADAR": {
    "ping": {
      "description": "Radar alive check"
    },
    "whoami": {
      "description": "Radar device identification"
    },
    "status": {
      "description": "Get radar status and readings",
      "responseFormat": "ok:range=X:velocity=X:confidence=X:movement=X"
    },
    "read": {
      "description": "Read radar measurements",
      "responseFormat": "ok:range=X:velocity=X:confidence=X:movement=X"
    },
    "set_range": {
      "description": "Set distance reading (simulation)",
      "args": ["centimeters"],
      "notes": "0-500 cm range"
    },
    "set_velocity": {
      "description": "Set velocity reading (simulation)",
      "args": ["meters_per_second"],
      "notes": "0.0-50.0 m/s range"
    }
  },
  "servo": {
    "ping": {
      "description": "Servo alive check"
    },
    "whoami": {
      "description": "Servo device identification"
    },
    "status": {
      "description": "Get servo current state",
      "responseFormat": "ok:state=X"
    },
    "open": {
      "description": "Extend/open servo actuator",
      "notes": "Takes ~6 seconds to complete"
    },
    "close": {
      "description": "Retract/close servo actuator",
      "notes": "Takes ~6 seconds to complete"
    }
  }
}
