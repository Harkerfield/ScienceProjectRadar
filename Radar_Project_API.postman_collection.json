    {
      "name": "Stepper Motor - PUT/PUSH Endpoints",
      "item": [
        {
          "name": "Find Home",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"method\": \"complete\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/stepper/home",
              "host": ["{{baseUrl}}"],
              "path": ["api", "stepper", "home"]
            },
            "description": "Find and calibrate home position. Method: 'complete' (2-phase) or 'fast' (1-phase)"
          }
        },
        {
          "name": "Move to Angle",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"angle\": 90\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/stepper/move",
              "host": ["{{baseUrl}}"],
              "path": ["api", "stepper", "move"]
            },
            "description": "Move to absolute angle (0-360°). Requires home calibration first."
          }
        },
        {
          "name": "Rotate by Degrees",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"degrees\": 45\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/stepper/rotate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "stepper", "rotate"]
            },
            "description": "Rotate by relative amount from current position. Positive=CW, Negative=CCW"
          }
        },
        {
          "name": "Set Speed",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"speed\": 2000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/stepper/speed",
              "host": ["{{baseUrl}}"],
              "path": ["api", "stepper", "speed"]
            },
            "description": "Set motor speed in microseconds (500-10000). Higher=slower, stronger torque"
          }
        },
        {
          "name": "Enable Motor",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enabled\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/stepper/enable",
              "host": ["{{baseUrl}}"],
              "path": ["api", "stepper", "enable"]
            },
            "description": "Enable or disable the motor"
          }
        },
        {
          "name": "Start/Stop Continuous Rotation",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rotating\": true,\n  \"direction\": \"CW\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/stepper/continuous",
              "host": ["{{baseUrl}}"],
              "path": ["api", "stepper", "continuous"]
            },
            "description": "Start or stop continuous rotation. Direction required when starting (CW or CCW)"
          }
        },
        {
          "name": "Set Max Speed",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"maxSpeed\": 10000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/stepper/max-speed",
              "host": ["{{baseUrl}}"],
              "path": ["api", "stepper", "max-speed"]
            },
            "description": "Set maximum speed limit in microseconds"
          }
        },
        {
          "name": "Set Min Speed",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"minSpeed\": 500\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/stepper/min-speed",
              "host": ["{{baseUrl}}"],
              "path": ["api", "stepper", "min-speed"]
            },
            "description": "Set minimum speed limit in microseconds"
          }
        }
