[Unit]
Description=Radar Project - Update Check (Daily at 3 AM)
Requires=radar-update-check.service

[Timer]
# Run daily at 03:00 (3 AM)
OnCalendar=daily
OnCalendar=*-*-* 03:00:00

# Also run on system startup
OnBootSec=2min

# Randomize startup by up to 5 minutes to avoid load spikes
RandomizedDelaySec=5min

[Install]
WantedBy=timers.target
