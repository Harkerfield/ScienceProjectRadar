# Auto detect text files and normalize line endings to LF
* text=auto

# Shell scripts (MUST be LF for Raspberry Pi)
*.sh text eol=lf
*.bash text eol=lf

# Python files (typically LF)
*.py text eol=lf
*.pyw text eol=lf

# MicroPython config
.micropico text eol=lf

# JavaScript/Node.js (usually LF)
*.js text eol=lf
*.json text eol=lf
*.vue text eol=lf

# Markdown
*.md text eol=lf
*.markdown text eol=lf

# Git files
.gitattributes text eol=lf
.gitignore text eol=lf

# Windows-specific
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.pyc binary
*.pyo binary
*.pyd binary
*.node binary
*.jar binary
*.dll binary
*.exe binary
*.so binary
*.dylib binary
