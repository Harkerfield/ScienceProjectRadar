{
  "name": "raspberry-pi-radar-fullstack",
  "version": "1.0.0",
  "description": "Full-stack radar application with stepper motor control for Raspberry Pi 4",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/index.js",
    "client:dev": "cd client && npm run serve",
    "server:start": "node server/index.js",
    "client:build": "cd client && npm run build",
    "build": "npm run client:build",
    "start": "npm run server:start",
    "install:client": "cd client && npm install",
    "install:server": "npm install",
    "install:all": "npm run install:server && npm run install:client",
    "test": "jest",
    "lint": "eslint server/ client/src/",
    "setup": "npm run install:all && npm run build"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "dotenv": "^16.3.1",
    "winston": "^3.10.0",
    "serialport": "^11.0.0",
    "node-bluetooth": "^1.2.0",
    "johnny-five": "^2.1.0",
    "raspi-io": "^12.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.0",
    "jest": "^29.6.2",
    "eslint": "^8.46.0",
    "@eslint/js": "^8.46.0"
  },
  "keywords": [
    "raspberry-pi",
    "radar",
    "stepper-motor",
    "vue",
    "nodejs",
    "iot",
    "fullstack"
  ],
  "author": "Radar Project",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-username/raspberry-pi-radar-fullstack.git"
  }
}