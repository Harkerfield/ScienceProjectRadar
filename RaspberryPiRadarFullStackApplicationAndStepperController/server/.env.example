# Environment Configuration
# Copy this file to .env and adjust values as needed

# Server Configuration
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:8080

# Hardware Configuration - Stepper Motor
STEPPER_PIN_STEP=18
STEPPER_PIN_DIR=19
STEPPER_PIN_ENABLE=20
STEPPER_PIN_RESET=21
STEPPER_STEPS_PER_REV=200
STEPPER_MAX_SPEED=500
STEPPER_MIN_SPEED=10

# UART Communication with Raspberry Pi Pico
PICO_UART_PORT=/dev/ttyAMA0
PICO_UART_BAUD_RATE=115200
PICO_UART_ENABLED=true
PICO_DATA_TIMEOUT=5000

# Hardware Configuration - Radar
RADAR_SERIAL_PORT=/dev/ttyUSB0
RADAR_BAUD_RATE=115200
RADAR_SCAN_INTERVAL=100
RADAR_DETECTION_THRESHOLD=50

# Network Configuration
WIFI_INTERFACE=wlan0
BLUETOOTH_DEVICE_NAME=RadarController

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_MAX_SIZE=5242880
LOG_FILE_MAX_FILES=5

# Security (change in production)
API_SECRET=your-secret-key-here
CORS_ORIGIN=http://localhost:8080

# Database (if using one)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=radar_system
# DB_USER=radar_user
# DB_PASSWORD=your-password