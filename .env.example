# Environment Configuration Template
# Copy to .env in root and in server/client folders
# Fill in values for your platform

# ==========================================
# GENERAL SETTINGS
# ==========================================

# Environment type
NODE_ENV=development

# Server port
PORT=3000

# API base URL (for frontend to find backend)
# Leave empty to auto-detect based on hostname
# Examples:
#   http://localhost:3000/api              (Windows/local dev)
#   http://radar-pi:3000/api               (Raspberry Pi hostname)
#   http://radar-pi.local:3000/api         (Raspberry Pi mDNS)
VUE_APP_API_BASE_URL=

# Socket.io URL (for real-time communication)
# Leave empty to auto-detect based on hostname
# Examples:
#   http://localhost:3000                  (Windows/local dev)
#   http://radar-pi:3000                   (Raspberry Pi hostname)
#   http://radar-pi.local:3000             (Raspberry Pi mDNS)
VUE_APP_SOCKET_URL=

# ==========================================
# PICO/UART SETTINGS
# ==========================================

# Enable UART communication with Pico Master
# Set to true on Raspberry Pi, false on Windows/Linux
PICO_UART_ENABLED=false

# UART port (Raspberry Pi only)
# Usually /dev/ttyAMA0 on Pi GPIO pins 14/15
PICO_UART_PORT=/dev/ttyAMA0

# UART baud rate (bits per second)
PICO_UART_BAUD_RATE=115200

# ==========================================
# LOGGING & DEBUGGING
# ==========================================

# Log level: debug, info, warn, error
LOG_LEVEL=debug

# Enable detailed console output
DEBUG=*

# ==========================================
# PLATFORM-SPECIFIC EXAMPLES
# ==========================================

# ---- WINDOWS DEVELOPMENT ----
# NODE_ENV=development
# PORT=3000
# VUE_APP_API_BASE_URL=http://localhost:3000/api
# PICO_UART_ENABLED=false
# LOG_LEVEL=debug

# ---- RASPBERRY PI PRODUCTION ----
# NODE_ENV=production
# PORT=3000
# VUE_APP_API_BASE_URL=http://localhost:3000/api
# PICO_UART_ENABLED=true
# PICO_UART_PORT=/dev/ttyAMA0
# PICO_UART_BAUD_RATE=115200

# ---- LINUX DEVELOPMENT ----
# NODE_ENV=development
# PORT=3000
# VUE_APP_API_BASE_URL=http://localhost:3000/api
# PICO_UART_ENABLED=false
# LOG_LEVEL=debug
